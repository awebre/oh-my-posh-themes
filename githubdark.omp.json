{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none",
            "macos": "\uf179"
          },
          "template": "{{ if .WSL }}WSL at {{ end }}{{.Icon}}",
          "foreground": "#9ea7b3",
          "type": "os",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "mapped_shell_names": {
              "pwsh": "\uf120 pwsh",
              "zsh": "\ue795 zsh"
            }
          },
          "template": " {{ .Name }}",
          "foreground": "#79c0ff",
          "type": "shell",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "style": "agnoster"
          },
          "template": " {{ .Path }} ",
          "foreground": "#fbe59e",
          "type": "path",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_status": true
          },
          "template": "\uf1d3 {{ .HEAD }}{{ .BranchStatus }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }} ",
          "foreground": "#F1502F",
          "type": "git",
          "style": "plain"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "foreground": "#ffffff",
          "templates_logic": "first_match",
          "type": "text",
          "style": "plain",
          "templates": [
            "{{ if .SSHSession }}{{ .UserName }}{{ end }}",
            "{{ .UserName }}"
          ]
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "{{ if .SSHSession }} @{{ .HostName }}{{ end }}",
          "foreground": "#9ea7b3",
          "type": "session",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": " | root",
          "foreground": "#e82a2f",
          "type": "root",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_package_manager": true,
            "npm_icon": "\ue71e",
            "yarn_icon": "\ue6a7"
          },
          "template": " | {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }}{{ else }}\ue718{{ end }} {{ .Full }}",
          "foreground": "#acf7b6",
          "type": "node",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "fetch_package_manager": true,
            "npm_icon": "\ue71e",
            "yarn_icon": "\ue6a7"
          },
          "template": " | \ue7ba {{ .Major }}",
          "foreground": "#acf7b6",
          "type": "react",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": " | \ue70c{{ if .Unsupported }}\uf071{{ else }} {{ .Full }}{{ end }}",
          "foreground": "#cb9eff",
          "type": "dotnet",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": " | \uebd8 {{ .Name }}",
          "foreground": "#9ec3f0",
          "type": "az",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": " | \uf2db \uf0e7",
          "type": "sysinfo",
          "style": "plain",
          "foreground_templates": [
            "{{if lt .Load1 5.0 }}#caeaff{{end}}",
            "{{if gt .Load1 5.0 }}#e7811d{{end}}"
          ]
        },
        {
          "properties": {
            "cache_duration": "none",
            "charged_icon": "\uf240 ",
            "charging_icon": "\uf0e7 ",
            "discharging_icon": "\uf242 ",
            "display_error": true,
            "not_charging_icon": "\uf244 "
          },
          "template": " | {{ if not .Error }}{{ .Icon }}{{ if lt .Percentage 50 }}{{ .Percentage }} \uf295 {{ end }}{{ end }}{{ .Error }}",
          "type": "battery",
          "style": "plain",
          "foreground_templates": [
            "{{if eq \"Charging\" .State.String}}#26cd4d{{end}}",
            "{{if eq \"Discharging\" .State.String}}#f0b72f{{end}}",
            "{{if eq \"Full\" .State.String}}#9ea7b3{{end}}",
            "#f0b72f"
          ]
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": " | {{ .CurrentDate | date .Format }} \uf113",
          "foreground": "#71b7ff",
          "type": "time",
          "style": "plain"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": "\udb81\ude0d ",
          "foreground": "#71b7ff",
          "type": "status",
          "style": "plain",
          "foreground_templates": [
            "{{ if .Error }}#e82a2f{{ end }}"
          ]
        }
      ],
      "newline": true
    }
  ],
  "version": 3
}
